---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { horses, getHorseBySlug } from '@/data/horses';
import { asset } from '@/utils/asset';

export async function getStaticPaths() {
  return horses.map(horse => ({
    params: { slug: horse.slug },
  }));
}

const { slug } = Astro.params;
const horse = getHorseBySlug(slug!);

if (!horse) {
  return Astro.redirect('/404');
}
---

<Layout 
  title={horse.name}
  description={`Profil lengkap ${horse.name} - ${horse.description}`}
  image={horse.image}
>
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="horse-hero">
      <div class="horse-hero-bg">
        <img src={asset(horse.image)} alt={horse.name} />
        <div class="overlay"></div>
      </div>
      <div class="container">
        <div class="horse-hero-content">
          <a href="/horses" class="hero-back-link">← Semua Kuda Pacu</a>
          <div class="hero-badges">
            <span class="hero-badge badge-breed">{horse.breed}</span>
            <span class="hero-badge badge-province">📍 {horse.province}</span>
            {horse.featured && <span class="hero-badge badge-featured">⭐ Featured</span>}
          </div>
          <h1 class="horse-name">{horse.name}</h1>
          <div class="hero-stat-pills">
            <span class="hero-pill">🏆 {horse.wins} Kemenangan</span>
            <span class="hero-pill">⚡ Speed {horse.stats.speed}</span>
            <span class="hero-pill">🎯 {horse.specialty}</span>
            <span class="hero-pill">🎂 {horse.age} Tahun</span>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Horse Details -->
    <section class="section">
      <div class="container">
        <div class="horse-detail-grid">
          <!-- Main Info -->
          <div class="main-content">
            <div class="card detail-card">
              <h2>Tentang {horse.name}</h2>
              <p class="description">{horse.description}</p>
              
              <div class="info-grid">
                <div class="info-item">
                  <span class="info-label">Breed</span>
                  <span class="info-value">{horse.breed}</span>
                </div>
                <div class="info-item">
                  <span class="info-label">Umur</span>
                  <span class="info-value">{horse.age} tahun</span>
                </div>
                <div class="info-item">
                  <span class="info-label">Total Kemenangan</span>
                  <span class="info-value wins-value">{horse.wins}x</span>
                </div>
                <div class="info-item">
                  <span class="info-label">Provinsi</span>
                  <span class="info-value info-value-sm">{horse.province}</span>
                </div>
                <div class="info-item">
                  <span class="info-label">Spesialisasi</span>
                  <span class="info-value info-value-sm">{horse.specialty}</span>
                </div>
                <div class="info-item">
                  <span class="info-label">Stable</span>
                  <span class="info-value info-value-sm">{horse.stable}</span>
                </div>
              </div>
            </div>
            
            <!-- Stats -->
            <div class="card stats-card">
              <h2>Statistik Performa</h2>
              <div class="stats-bars">
                <div class="stat-bar">
                  <div class="stat-header">
                    <span>Speed — Kecepatan</span>
                    <span class="stat-number">{horse.stats.speed}<span class="stat-max">/100</span></span>
                  </div>
                  <div class="progress-bar">
                    <div class="progress-fill speed-fill" style={`width: ${horse.stats.speed}%`}></div>
                  </div>
                </div>
                
                <div class="stat-bar">
                  <div class="stat-header">
                    <span>Stamina — Ketahanan</span>
                    <span class="stat-number">{horse.stats.stamina}<span class="stat-max">/100</span></span>
                  </div>
                  <div class="progress-bar">
                    <div class="progress-fill stamina-fill" style={`width: ${horse.stats.stamina}%`}></div>
                  </div>
                </div>
                
                <div class="stat-bar">
                  <div class="stat-header">
                    <span>Power — Tenaga</span>
                    <span class="stat-number">{horse.stats.power}<span class="stat-max">/100</span></span>
                  </div>
                  <div class="progress-bar">
                    <div class="progress-fill power-fill" style={`width: ${horse.stats.power}%`}></div>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Achievements -->
            <div class="card achievements-card">
              <h2>🏆 Pencapaian</h2>
              <ul class="achievements-list">
                {horse.achievements.map(achievement => (
                  <li>
                    <span class="ach-dot"></span>
                    {achievement}
                  </li>
                ))}
              </ul>
            </div>
          </div>
          
          <!-- Sidebar -->
          <aside class="sidebar">
            <div class="card horse-img-card">
              <div class="horse-img-label">✨ Ilustrasi Karakter</div>
              <img src={asset(horse.image)} alt={`Ilustrasi karakter ${horse.name}`} class="sidebar-image" />
            </div>

            {horse.imageReal && (
              <div class="card horse-img-card">
                <div class="horse-img-label">📷 Foto Kuda Asli</div>
                <img src={asset(horse.imageReal)} alt={`Foto asli ${horse.name}`} class="sidebar-image" />
              </div>
            )}

            <div class="card stable-card">
              <h3 class="stable-card-title">Informasi Stable</h3>
              <div class="stable-info-row">
                <span class="stable-icon">🏠</span>
                <div>
                  <div class="stable-info-label">Stable</div>
                  <div class="stable-info-value">{horse.stable}</div>
                </div>
              </div>
              <div class="stable-info-row">
                <span class="stable-icon">📍</span>
                <div>
                  <div class="stable-info-label">Provinsi</div>
                  <div class="stable-info-value">{horse.province}</div>
                </div>
              </div>
              <div class="stable-info-row">
                <span class="stable-icon">🎯</span>
                <div>
                  <div class="stable-info-label">Spesialisasi</div>
                  <div class="stable-info-value">{horse.specialty}</div>
                </div>
              </div>
            </div>
            
            <a href="/horses" class="btn btn-secondary back-btn">← Kembali ke Daftar</a>
          </aside>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  /* ── Hero ───────────────────────────────────────────── */
  .horse-hero {
    position: relative;
    min-height: 540px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .horse-hero-bg {
    position: absolute;
    inset: 0;
  }

  .horse-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  /* diagonal: opaque on left (text safe), transparent on right (show horse) */
  .overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right,  rgba(8,8,8,0.92) 0%, rgba(8,8,8,0.65) 55%, rgba(8,8,8,0.18) 100%),
      linear-gradient(to top,    rgba(8,8,8,0.80) 0%, transparent 50%);
  }

  .horse-hero-content {
    position: relative;
    z-index: 10;
    padding-bottom: var(--spacing-xl);
    max-width: 60%;
  }

  /* back link */
  .hero-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255,255,255,0.65);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    margin-bottom: var(--spacing-md);
    transition: color 0.2s;
  }
  .hero-back-link:hover { color: #fff; }

  /* badge row above name */
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.28rem 0.75rem;
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    line-height: 1;
  }

  .badge-breed {
    background: rgba(192,192,192,0.18);
    border: 1px solid rgba(192,192,192,0.45);
    color: #e0e0e0;
  }

  .badge-province {
    background: rgba(192,18,26,0.22);
    border: 1px solid rgba(192,18,26,0.55);
    color: #ffb3b6;
  }

  .badge-featured {
    background: rgba(220,163,0,0.22);
    border: 1px solid rgba(220,163,0,0.55);
    color: #ffe07a;
  }

  /* horse name */
  .horse-name {
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 900;
    font-style: italic;
    letter-spacing: -0.025em;
    line-height: 1;
    margin-bottom: 1rem;
    text-shadow: 0 4px 24px rgba(0,0,0,0.6);
    color: #fff;
  }

  /* stat pill row */
  .hero-stat-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.85rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    backdrop-filter: blur(6px);
    border-radius: 100px;
    font-size: 0.82rem;
    font-weight: 600;
    color: #eeeeee;
    white-space: nowrap;
  }

  /* ── Detail grid ────────────────────────────────────── */
  .horse-detail-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--spacing-xl);
  }

  /* ── Detail card ────────────────────────────────────── */
  .detail-card,
  .stats-card,
  .achievements-card {
    padding: var(--spacing-lg);
  }

  .detail-card h2,
  .stats-card h2,
  .achievements-card h2 {
    font-size: 1.2rem;
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-sm);
    border-bottom: 2px solid var(--primary);
    letter-spacing: -0.01em;
  }

  .description {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--text-muted);
    margin-bottom: var(--spacing-lg);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-sm);
  }

  .info-item {
    text-align: center;
    padding: var(--spacing-md) var(--spacing-sm);
    background: var(--bg-hover);
    border-radius: 10px;
    border: 1px solid var(--border);
  }

  .info-label {
    display: block;
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
  }

  .info-value {
    display: block;
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--primary);
    letter-spacing: -0.02em;
  }

  /* smaller text for long values */
  .info-value-sm {
    font-size: 0.88rem !important;
    font-weight: 700 !important;
    letter-spacing: 0 !important;
    color: var(--text) !important;
    line-height: 1.3;
  }

  .wins-value { color: var(--primary); }

  /* ── Stats bars ─────────────────────────────────────── */
  .stats-bars {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .stat-bar { display: flex; flex-direction: column; gap: 0.5rem; }

  .stat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .stat-number {
    color: var(--primary);
    font-size: 1.15rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
  }

  .stat-max {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .progress-bar {
    height: 14px;
    background: var(--bg-hover);
    border-radius: 100px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    border-radius: 100px;
    transition: width 1.1s cubic-bezier(0.22,1,0.36,1);
  }

  .speed-fill   { background: linear-gradient(90deg, #C0121A, #e04050); }
  .stamina-fill { background: linear-gradient(90deg, #1E5B99, #3b82c4); }
  .power-fill   { background: linear-gradient(90deg, #B86A0A, #e08924); }

  /* ── Achievements ───────────────────────────────────── */
  .achievements-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .achievements-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.7rem var(--spacing-md);
    background: var(--bg-hover);
    border-radius: 8px;
    font-size: 0.97rem;
    line-height: 1.5;
  }

  .ach-dot {
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--primary);
    margin-top: 0.4rem;
  }

  /* ── Sidebar ────────────────────────────────────────── */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .horse-img-card {
    padding: var(--spacing-sm) !important;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .horse-img-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    padding: 0.25rem 0.25rem 0.4rem;
    border-bottom: 1px solid var(--border);
  }

  .sidebar-image {
    width: 100%;
    border-radius: 8px;
    display: block;
  }

  /* stable info card */
  .stable-card {
    padding: var(--spacing-md);
  }

  .stable-card-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-sm);
    border-bottom: 2px solid var(--primary);
    letter-spacing: -0.01em;
  }

  .stable-info-row {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--border);
  }

  .stable-info-row:last-child { border-bottom: none; }

  .stable-icon {
    font-size: 1.3rem;
    width: 1.6rem;
    text-align: center;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .stable-info-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    color: var(--text-muted);
    margin-bottom: 0.15rem;
  }

  .stable-info-value {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .back-btn {
    width: 100%;
    text-align: center;
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 768px) {
    .horse-hero-content { max-width: 100%; }

    .horse-detail-grid {
      grid-template-columns: 1fr;
    }

    .info-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .horse-name { font-size: 2.4rem; }

    .info-grid {
      grid-template-columns: 1fr;
    }

    .hero-stat-pills { gap: 0.4rem; }
    .hero-pill { font-size: 0.75rem; padding: 0.3rem 0.65rem; }
  }
</style>
