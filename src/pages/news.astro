---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { news, getRecentNews, getNewsByCategory } from '@/data/news';

const allNews = news;
const categories = ['news', 'analysis', 'interview', 'event'];
---

<Layout 
  title="Berita & Artikel" 
  description="Berita terkini, analisis mendalam, dan artikel menarik seputar dunia pacuan kuda."
>
  <Header />
  
  <main>
    <section class="page-header">
      <div class="container">
        <h1>📰 Berita & Artikel</h1>
        <p>Update terbaru dari dunia pacuan kuda</p>
      </div>
    </section>
    
    <!-- Featured News -->
    {allNews.filter(n => n.featured).length > 0 && (
      <section class="section">
        <div class="container">
            {allNews.filter(n => n.featured).slice(0, 1).map(article => (
              <article class="featured-main card">
                <img src={article.image} alt={article.title} loading="lazy" />
                <div class="featured-content">
                  <span class={`category-badge ${article.category}`}>{article.category}</span>
                  <h2>{article.title}</h2>
                  <p>{article.excerpt}</p>
                  <div class="article-meta">
                    <span>✍️ {article.author}</span>
                    <span>📅 {new Date(article.date).toLocaleDateString('id-ID')}</span>
                  </div>
                  <div class="tags">
                    {article.tags.map(tag => (
                      <span class="tag">#{tag}</span>
                    ))}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}
    
    <!-- Category Filter -->
    <section class="section">
      <div class="container">
        <div class="filter-buttons">
          <button class="filter-btn active" data-category="all">Semua</button>
          <button class="filter-btn" data-category="news">News</button>
          <button class="filter-btn" data-category="analysis">Analysis</button>
          <button class="filter-btn" data-category="interview">Interview</button>
          <button class="filter-btn" data-category="event">Event</button>
        </div>
        
        <!-- News Grid -->
        <div class="news-grid">
          {allNews.map(article => (
            <article class="news-card card" data-category={article.category}>
              <div class="news-image">
                <img src={article.image} alt={article.title} loading="lazy" />
                {article.featured && (
                  <span class="featured-badge">⭐ Featured</span>
                )}
              </div>
              <div class="news-body">
                <span class={`category-badge ${article.category}`}>{article.category}</span>
                <h3>{article.title}</h3>
                <p>{article.excerpt}</p>
                <div class="article-meta">
                  <span>✍️ {article.author}</span>
                  <span>📅 {new Date(article.date).toLocaleDateString('id-ID')}</span>
                </div>
                <div class="tags">
                  {article.tags.map(tag => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .page-header {
    position: relative;
    background-image: url('/bg-silver-paint.jpeg');
    background-size: cover;
    background-position: center;
    padding: var(--spacing-xl) 0;
    text-align: center;
    margin-bottom: var(--spacing-xl);
    overflow: hidden;
  }
  
  .page-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(220, 20, 60, 0.65) 0%, rgba(30, 10, 10, 0.75) 100%);
    z-index: 0;
  }
  
  .page-header > * {
    position: relative;
    z-index: 1;
  }
  
  .page-header .container {
    position: relative;
    z-index: 1;
  }
  
  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--spacing-sm);
    background: linear-gradient(
      90deg,
      #A8A8A8 0%,
      #D8D8D8 20%,
      #FFFFFF 38%,
      #F0F0F0 42%,
      #C0C0C0 55%,
      #E8E8E8 70%,
      #FFFFFF 82%,
      #B0B0B0 100%
    );
    background-size: 300% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: glossySweep 10s linear infinite;
  }
  
  @keyframes glossySweep {
    0% { background-position: 0% center; }
    100% { background-position: 300% center; }
}
  
  .page-header p {
    font-size: 1.2rem;
    background: linear-gradient(
      90deg,
      #909090 0%,
      #C8C8C8 25%,
      #F5F5F5 45%,
      #C8C8C8 55%,
      #909090 100%
    );
    background-size: 300% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: glossySweep 12s linear infinite;
  }
  
  .featured-grid {
    margin-bottom: var(--spacing-xl);
  }
  
  .featured-main {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--spacing-xl);
    padding: 0;
    overflow: hidden;
  }
  
  .featured-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .featured-content {
    padding: var(--spacing-xl);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }
  
  .featured-content h2 {
    font-size: 2rem;
    line-height: 1.3;
    margin-bottom: 0;
  }
  
  .featured-content p {
    font-size: 1.1rem;
    line-height: 1.7;
    flex: 1;
  }
  
  .filter-buttons {
    display: flex;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xl);
    flex-wrap: wrap;
    justify-content: center;
  }
  
  .filter-btn {
    padding: 0.75rem 1.5rem;
    background: var(--bg-card);
    border: 2px solid var(--border);
    border-radius: 25px;
    color: var(--text-secondary);
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
    text-transform: capitalize;
  }
  
  .filter-btn:hover {
    border-color: var(--primary);
    color: var(--text-primary);
  }
  
  .filter-btn.active {
    background: var(--primary);
    border-color: var(--primary);
    color: var(--text-primary);
  }
  
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: var(--spacing-md);
  }
  
  .news-card {
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
    opacity: 1;
    transition: all var(--transition-medium);
  }
  
  .news-card.hidden {
    display: none;
  }
  
  .news-image {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
  }
  
  .news-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .featured-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: var(--primary);
    padding: 0.375rem 0.875rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
  }
  
  .news-body {
    padding: var(--spacing-md);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    flex: 1;
  }
  
  .category-badge {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    width: fit-content;
  }
  
  .category-badge.news {
    background: rgba(52, 152, 219, 0.2);
    color: #3498db;
  }
  
  .category-badge.analysis {
    background: rgba(155, 89, 182, 0.2);
    color: #9b59b6;
  }
  
  .category-badge.interview {
    background: rgba(241, 196, 15, 0.2);
    color: #f1c40f;
  }
  
  .category-badge.event {
    background: rgba(46, 204, 113, 0.2);
    color: #2ecc71;
  }
  
  .news-body h3 {
    font-size: 1.25rem;
    line-height: 1.4;
    margin-bottom: 0;
  }
  
  .news-body p {
    flex: 1;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .article-meta {
    display: flex;
    justify-content: space-between;
    gap: var(--spacing-sm);
    font-size: 0.85rem;
    color: var(--text-muted);
    padding-top: var(--spacing-sm);
    border-top: 1px solid var(--border);
  }
  
  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  
  .tag {
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: color var(--transition-fast);
    cursor: pointer;
  }
  
  .tag:hover {
    color: var(--primary);
  }
  
  @media (max-width: 768px) {
    .featured-main {
      grid-template-columns: 1fr;
    }
    
    .news-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Category filtering
  const filterButtons = document.querySelectorAll('.filter-btn');
  const newsCards = document.querySelectorAll('.news-card');
  
  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      const category = button.dataset.category;
      
      // Update active button
      filterButtons.forEach(btn => btn.classList.remove('active'));
      button.classList.add('active');
      
      // Filter news cards
      newsCards.forEach(card => {
        if (category === 'all' || card.dataset.category === category) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
