---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { races, getUpcomingRaces, getFinishedRaces, getG1Races, type Race } from '@/data/races';
import { asset } from '@/utils/asset';

const upcoming = getUpcomingRaces();
const finished = getFinishedRaces();
const g1Races  = getG1Races();

// Tab definitions — single source of truth, no data duplication
const tabs: { id: string; label: string; title: string; data: Race[]; empty: string }[] = [
  { id: 'upcoming', label: 'Mendatang',  title: '📅 Race Mendatang',  data: upcoming,  empty: 'Tidak ada race mendatang saat ini.' },
  { id: 'finished', label: 'Selesai',    title: '🏆 Race Selesai',    data: finished,  empty: 'Belum ada race yang selesai.' },
  { id: 'g1',       label: 'G1 Only',    title: '⭐ Grade 1 Races',   data: g1Races,   empty: 'Tidak ada race G1.' },
  { id: 'all',      label: 'Semua',      title: '📋 Semua Race',      data: races,     empty: 'Tidak ada data race.' },
];
---

<Layout 
  title="Jadwal & Hasil Race" 
  description="Jadwal lengkap pacuan kuda, hasil race terkini, dan informasi detail setiap event."
>
  <Header />
  
  <main>
    <section class="page-header">
      <div class="container">
        <h1>🏁 Jadwal & Hasil Race</h1>
        <p>Ikuti semua event pacuan kuda terbesar</p>
      </div>
    </section>
    
    <!-- Filter Tabs -->
    <section class="section">
      <div class="container">
        <div class="tabs">
          {tabs.map((t, i) => (
            <button class={`tab${i === 0 ? ' active' : ''}`} data-tab={t.id}>{t.label}</button>
          ))}
        </div>

        {tabs.map((t, i) => (
          <div id={t.id} class={`tab-content${i === 0 ? ' active' : ''}`}>
            <h2 class="content-title">{t.title}</h2>
            <div class="races-list">
              {t.data.length > 0 ? t.data.map(race => (
                <article class={`race-item card${race.winner ? ' has-winner' : ''}`}>

                  {/* Stadium image — flush top/bottom/left */}
                  <div class="race-item-image">
                    <img src={asset(race.image)} alt={race.name} loading="lazy" />
                    <span class={`grade-badge ${race.grade.toLowerCase()}`}>{race.grade}</span>
                    {race.status === 'finished' && <span class="finished-badge">✅ Selesai</span>}
                    {race.status === 'upcoming' && <span class="upcoming-badge">📅 Mendatang</span>}
                    {race.status === 'ongoing'  && <span class="ongoing-badge">🔴 Live</span>}
                    {/* Mobile-only circular winner avatar overlaid on stadium image */}
                    {race.winner && race.winnerImage && (
                      <div class="winner-avatar-mobile">
                        <img src={asset(race.winnerImage)} alt={race.winner} loading="lazy" />
                        <span class="winner-avatar-crown">🏆</span>
                      </div>
                    )}
                  </div>

                  {/* Main content */}
                  <div class="race-item-content">
                    <h3>{race.name}</h3>
                    <div class="race-item-meta">
                      <span class="meta-item">📍 {race.location}</span>
                      <span class="meta-item">📏 {race.distance}</span>
                      <span class="meta-item">💰 {race.prize}</span>
                      {race.time && <span class="meta-item">⏱️ {race.time}</span>}
                    </div>
                    <p class="race-date">
                      {new Date(race.date).toLocaleDateString('id-ID', {
                        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
                      })}
                    </p>
                    <p class="race-description">{race.description}</p>
                    {race.participants && race.participants.length > 0 && (
                      <div class="participants">
                        <strong>Peserta:</strong> {race.participants.join(', ')}
                      </div>
                    )}
                  </div>

                  {/* Winner portrait — flush top/bottom/right, only when winner exists */}
                  {race.winner && (
                    <div class="race-winner-portrait">
                      {race.winnerImage
                        ? <img src={asset(race.winnerImage)} alt={race.winner} loading="lazy" />
                        : <div class="winner-portrait-placeholder">🏇</div>
                      }
                      <div class="winner-portrait-label">
                        <span class="winner-crown-icon">🏆</span>
                        <span class="winner-portrait-name">{race.winner}</span>
                      </div>
                    </div>
                  )}

                </article>
              )) : (
                <p class="no-data">{t.empty}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .page-header {
    position: relative;
    background-image: url('/kudayu/bg-silver-paint.jpeg');
    background-size: cover;
    background-position: center;
    padding: var(--spacing-xl) 0;
    text-align: center;
    margin-bottom: var(--spacing-xl);
    overflow: hidden;
  }
  
  .page-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(220, 20, 60, 0.65) 0%, rgba(30, 10, 10, 0.75) 100%);
    z-index: 0;
  }
  
  .page-header > * {
    position: relative;
    z-index: 1;
  }
  
  .page-header .container {
    position: relative;
    z-index: 1;
  }
  
  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--spacing-sm);
    background: linear-gradient(
      90deg,
      #A8A8A8 0%,
      #D8D8D8 20%,
      #FFFFFF 38%,
      #F0F0F0 42%,
      #C0C0C0 55%,
      #E8E8E8 70%,
      #FFFFFF 82%,
      #B0B0B0 100%
    );
    background-size: 300% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: glossySweep 10s linear infinite;
  }
  
  @keyframes glossySweep {
    0% { background-position: 0% center; }
    100% { background-position: 300% center; }
}
  
  .page-header p {
    font-size: 1.2rem;
    background: linear-gradient(
      90deg,
      #909090 0%,
      #C8C8C8 25%,
      #F5F5F5 45%,
      #C8C8C8 55%,
      #909090 100%
    );
    background-size: 300% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: glossySweep 12s linear infinite;
  }
  
  .tabs {
    display: flex;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xl);
    border-bottom: 2px solid var(--border);
    flex-wrap: wrap;
  }
  
  .tab {
    padding: var(--spacing-sm) var(--spacing-md);
    background: none;
    border: none;
    color: var(--text-secondary);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
  }
  
  .tab:hover {
    color: var(--text-primary);
  }
  
  .tab.active {
    color: var(--primary);
    border-bottom-color: var(--primary);
  }
  
  .tab-content {
    display: none;
  }
  
  .tab-content.active {
    display: block;
  }
  
  .content-title {
    font-size: 1.75rem;
    margin-bottom: var(--spacing-lg);
  }
  
  .races-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }
  
  .race-item {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: var(--spacing-lg);
    padding: var(--spacing-md);
    align-items: stretch;
  }

  .race-item.has-winner {
    grid-template-columns: 280px 1fr 148px;
    align-items: stretch;
  }
  
  .race-item-image {
    position: relative;
    overflow: hidden;
    margin-top: calc(-1 * var(--spacing-md));
    margin-bottom: calc(-1 * var(--spacing-md));
    margin-left: calc(-1 * var(--spacing-md));
    min-height: 160px;
  }
  
  .race-item-image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform var(--transition-slow);
  }

  .race-item:hover .race-item-image img {
    transform: scale(1.05);
  }
  
  .grade-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    padding: 0.375rem 0.875rem;
    border-radius: 20px;
    font-weight: 700;
    font-size: 0.875rem;
  }
  
  .grade-badge.g1 {
    background: var(--secondary);
    color: var(--bg-dark);
  }
  
  .grade-badge.g2 {
    background: #C0C0C0;
    color: var(--bg-dark);
  }
  
  .grade-badge.g3 {
    background: #CD7F32;
    color: var(--text-primary);
  }
  
  .finished-badge,
  .upcoming-badge,
  .ongoing-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 0.7rem;
    border-radius: 20px;
    backdrop-filter: blur(4px);
  }

  .finished-badge {
    background: rgba(46, 204, 113, 0.18);
    color: #2ecc71;
    border: 1px solid rgba(46, 204, 113, 0.35);
  }

  .upcoming-badge {
    background: rgba(52, 152, 219, 0.18);
    color: #3498db;
    border: 1px solid rgba(52, 152, 219, 0.35);
  }

  .ongoing-badge {
    background: rgba(231, 76, 60, 0.22);
    color: #e74c3c;
    border: 1px solid rgba(231, 76, 60, 0.35);
  }

  /* Mobile winner avatar — hidden on desktop */
  .winner-avatar-mobile {
    display: none;
  }

  /* Winner Portrait — flush to card right edge */
  .race-winner-portrait {
    position: relative;
    align-self: stretch;
    margin-top: calc(-1 * var(--spacing-md));
    margin-bottom: calc(-1 * var(--spacing-md));
    margin-right: calc(-1 * var(--spacing-md));
    min-height: 160px;
    overflow: hidden;
  }

  .race-winner-portrait img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform var(--transition-slow);
  }

  .race-item:hover .race-winner-portrait img {
    transform: scale(1.06);
  }

  .winner-portrait-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    background: var(--bg-hover);
  }

  .winner-portrait-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.80) 0%, transparent 100%);
    padding: 2rem 0.75rem 0.65rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .winner-crown-icon {
    font-size: 0.95rem;
    line-height: 1;
  }

  .winner-portrait-name {
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--secondary);
    text-align: center;
    line-height: 1.35;
    word-break: break-word;
  }
  
  .race-item-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    justify-content: center;
    padding: var(--spacing-sm) 0;
  }
  
  .race-item-content h3 {
    font-size: 1.5rem;
    margin-bottom: 0;
  }
  
  .race-item-meta {
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }
  
  .meta-item {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  
  .race-date {
    color: var(--text-secondary);
    font-weight: 600;
  }
  
  .race-description {
    line-height: 1.6;
  }
  
  .participants {
    padding: var(--spacing-sm);
    background: var(--bg-hover);
    border-left: 3px solid var(--primary);
    border-radius: 4px;
    font-size: 0.95rem;
  }
  
  .status-badge {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    width: fit-content;
  }
  
  .status-badge.upcoming {
    background: rgba(52, 152, 219, 0.2);
    color: #3498db;
  }
  
  .status-badge.ongoing {
    background: rgba(231, 76, 60, 0.2);
    color: #e74c3c;
  }
  
  .status-badge.finished {
    background: rgba(46, 204, 113, 0.2);
    color: #2ecc71;
  }
  
  .no-data {
    text-align: center;
    padding: var(--spacing-xl);
    color: var(--text-muted);
    font-size: 1.1rem;
  }
  
  @media (max-width: 1024px) {
    /* Tablet: shrink fixed columns */
    .race-item {
      grid-template-columns: 220px 1fr;
      gap: var(--spacing-md);
    }
    .race-item.has-winner {
      grid-template-columns: 200px 1fr 120px;
    }
    .race-item-content h3 {
      font-size: 1.25rem;
    }
  }

  @media (max-width: 768px) {
    /* Mobile: stack vertically */
    .race-item,
    .race-item.has-winner {
      grid-template-columns: 1fr;
      gap: 0;
    }

    /* Stadium image: flush top + sides, fixed height */
    .race-item-image {
      margin: calc(-1 * var(--spacing-md)) calc(-1 * var(--spacing-md)) 0;
      min-height: 200px;
      aspect-ratio: 16 / 7;
    }

    /* Hide the desktop flush-right portrait column */
    .race-winner-portrait {
      display: none;
    }

    /* Show the mobile circular avatar inside the stadium image */
    .winner-avatar-mobile {
      display: block;
      position: absolute;
      bottom: 0.85rem;
      right: 0.85rem;
      width: 72px;
      height: 72px;
      border-radius: 50%;
      overflow: hidden;
      border: 2.5px solid var(--secondary);
      box-shadow: 0 0 0 3px rgba(212,175,55,0.25), 0 2px 12px rgba(0,0,0,0.45);
      background: var(--bg-hover);
      z-index: 5;
    }

    .winner-avatar-mobile img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
    }

    .winner-avatar-crown {
      position: absolute;
      top: -10px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 0.85rem;
      line-height: 1;
      filter: drop-shadow(0 1px 3px rgba(0,0,0,0.6));
    }

    /* Content: normal padding */
    .race-item-content {
      padding: var(--spacing-sm) 0;
    }

    .race-item-content h3 {
      font-size: 1.15rem;
    }

    .race-item-meta {
      gap: 0.5rem var(--spacing-sm);
    }

    /* Tabs wrap nicely */
    .tabs {
      gap: 0.4rem;
    }
    .tab {
      padding: 0.5rem 0.9rem;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 480px) {
    .race-item-image {
      aspect-ratio: 16 / 8;
      min-height: 160px;
    }
    .winner-avatar-mobile {
      width: 60px;
      height: 60px;
    }
  }
</style>

<script>
  // Tab switching
  const tabs = document.querySelectorAll('.tab');
  const tabContents = document.querySelectorAll('.tab-content');
  
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const targetTab = tab.dataset.tab;
      
      // Remove active class from all tabs and contents
      tabs.forEach(t => t.classList.remove('active'));
      tabContents.forEach(c => c.classList.remove('active'));
      
      // Add active class to clicked tab and corresponding content
      tab.classList.add('active');
      document.getElementById(targetTab!)?.classList.add('active');
    });
  });
</script>
